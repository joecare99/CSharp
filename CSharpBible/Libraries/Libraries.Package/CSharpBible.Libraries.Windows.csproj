<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\Libraries_net.props" />
  <PropertyGroup>
	<TargetFramework>net8.0</TargetFramework>
	<NoDefaultExcludes>true</NoDefaultExcludes>
	<IsPackable>true</IsPackable>
	<IncludeBuildOutput>false</IncludeBuildOutput>
	<PackageId>CSharpBible.Libraries.Windows</PackageId>
	<Version>1.0.0</Version>
	<Title>CSharpBible Libraries Windows</Title>
	<Description>Windows-specific package for the CSharpBible libraries.</Description>
	<PackageReadmeFile>README.Windows.md</PackageReadmeFile>
	<PackageOutputPath>$(MSBuildProjectDirectory)\artifacts\nuget</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
	<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
	<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
	<None Include="README.Windows.md" Pack="true" PackagePath="\" />
	<None Include="$(UpDir)\..\bin\CommonDialogs\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\CommonDialogs\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\CommonDialogs_net\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\CommonDialogs_net\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\ConsoleLib_net\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\ConsoleLib_net\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\ExtendedConsole\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\ExtendedConsole\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\MVVM_BaseLib\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\MVVM_BaseLib\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\WFSystem.Windows.Data\$(Configuration)\**\*.dll" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
	<None Include="$(UpDir)\..\bin\WFSystem.Windows.Data\$(Configuration)\**\*.xml" Pack="true" PackagePath="lib\%(RecursiveDir)" Visible="false" />
  </ItemGroup>
</Project>