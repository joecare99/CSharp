<!--  Generated from LFM file  -->
<Window
    x:Class="WpfApp.Views.Frm_W2kMain"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Client-Anwendung für Windows 2000"
    Width="486"
    Height="315"
    Background="#F0F0F0"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BitmapImage x:Key="ToolbarImageList" UriSource="pack://application:,,,/Views/Images/ImageList1.png" />
        <CroppedBitmap x:Key="ToolbarNewImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,96,16,16" />
        <CroppedBitmap x:Key="ToolbarOpenImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,112,16,16" />
        <CroppedBitmap x:Key="ToolbarSaveImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,128,16,16" />
        <CroppedBitmap x:Key="ToolbarPreviewImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,144,16,16" />
        <CroppedBitmap x:Key="ToolbarPropertyImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,160,16,16" />
        <CroppedBitmap x:Key="ToolbarHelpImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,176,16,16" />
        <CroppedBitmap x:Key="ToolbarFindImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,192,16,16" />
        <CroppedBitmap x:Key="ToolbarReplaceImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,208,16,16" />
        <CroppedBitmap x:Key="ToolbarPrintImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,224,16,16" />
        <CroppedBitmap x:Key="ToolbarSendImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,240,16,16" />
        <CroppedBitmap x:Key="ToolbarCutImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,0,16,16" />
        <CroppedBitmap x:Key="ToolbarCopyImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,16,16,16" />
        <CroppedBitmap x:Key="ToolbarPasteImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,32,16,16" />
        <CroppedBitmap x:Key="ToolbarUndoImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,48,16,16" />
        <CroppedBitmap x:Key="ToolbarRedoImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,64,16,16" />
        <CroppedBitmap x:Key="ToolbarDeleteImage" Source="{StaticResource ToolbarImageList}" SourceRect="0,80,16,16" />
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="File1" Header="_Datei">
                <MenuItem
                    x:Name="FileNewItem"
                    Header="_Neu"
                    InputGestureText="Ctrl+N"
                    Command="{Binding NewDocumentCommand}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarNewImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    x:Name="FileOpenItem"
                    Header="_Öffnen"
                    InputGestureText="Ctrl+O"
                    Command="{Binding OpenDocumentCommand}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarOpenImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    x:Name="FileSaveItem"
                    Header="_Speichern"
                    InputGestureText="Ctrl+S"
                    Command="{Binding SaveDocumentCommand}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarSaveImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    x:Name="FileSaveAsItem"
                    Header="Speichern _unter..."
                    Command="{Binding SaveDocumentAsCommand}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarSaveImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem x:Name="FileSendItem" Header="Sen_den"  Command="{Binding SendDocumentCommand}">                    
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarSendImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem x:Name="FileExitItem" Header="_Beenden" Command="{Binding ExitApplicationCommand}" />
            </MenuItem>
            <MenuItem x:Name="Edit1" Header="_Bearbeiten">
                <MenuItem
                    x:Name="CutItem"
                    Header="_Ausschneiden"
                    InputGestureText="Ctrl+X" >
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarCutImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    x:Name="CopyItem"
                    Header="_Kopieren"
                    InputGestureText="Ctrl+C" >
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarCopyImage}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    x:Name="PasteItem"
                    Header="_Einfügen"
                    InputGestureText="Ctrl+V" >
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarPasteImage}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="Help1" Header="_Hilfe">
                <MenuItem x:Name="HelpAboutItem" Header="_Info..." >
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Source="{StaticResource ToolbarHelpImage}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        <DockPanel>
            <StatusBar DockPanel.Dock="Bottom"
                x:Name="StatusBar"
                Width="450"
                Height="23">
                <TextBlock Text="{Binding StatusText}" />
            </StatusBar>
            <ToolBar DockPanel.Dock="Top"
                x:Name="ToolBar1"
                Height="24">
                <Button x:Name="ToolButton1" ToolTip="Neu|Neue Datei erstellen" Command="{Binding NewDocumentCommand}">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarNewImage}"  Margin="-1"/>
                </Button>
                <Button x:Name="ToolButton2" ToolTip="Öffnen|Datei öffnen" Command="{Binding OpenDocumentCommand}">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarOpenImage}"  Margin="-1"/>
                </Button>
                <Button x:Name="ToolButton3" ToolTip="Speichern|Aktuelle Datei speichern" Command="{Binding SaveDocumentCommand}">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarSaveImage}"  Margin="-1"/>
                </Button>
                <Separator />
                <Button x:Name="ToolButton5" ToolTip="Senden|Datei versenden" Command="{Binding SendDocumentCommand}">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarSendImage}"  Margin="-1"/>
                </Button>
                <Separator />
                <Button x:Name="ToolButton7" ToolTip="Ausschneiden|Markiertes Objekt in die Zwischenablage verschieben">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarCutImage}"  Margin="-1"/>
                </Button>
                <Button x:Name="ToolButton8" ToolTip="Kopieren|Markiertes Objekt in die Zwischenablage kopieren">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarCopyImage}"  Margin="-1"/>
                </Button>
                <Button x:Name="ToolButton9" ToolTip="Einfügen|Inhalt der Zwischenablage einfügen">
                    <Image Width="16" Height="16" Source="{StaticResource ToolbarPasteImage}"  Margin="-1"/>
                </Button>
            </ToolBar>
            <TextBox
                x:Name="RichEdit1"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
                AcceptsTab="True"
                Text="{Binding Document.Text, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Center" />
        </DockPanel>
    </DockPanel>
</Window>
