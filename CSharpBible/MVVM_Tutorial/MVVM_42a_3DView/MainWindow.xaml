<Window
    x:Class="MVVM_42a_3DView.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MVVM_42a_3DView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mvvm="clr-namespace:MVVM_42a_3DView.ViewModels"
    xmlns:p="clr-namespace:MVVM_42a_3DView.Properties"
    Title="{x:Static p:Resources.Title}"
    Width="800"
    Height="450"
    ToolTip="{x:Static p:Resources.Description}"
    mc:Ignorable="d">
    <Window.DataContext>
        <mvvm:MainWindowViewModel />
    </Window.DataContext>
    <TabControl>
        <TabItem Header="{x:Static p:Resources.Title}">
            <Frame Source="/Views/ThreeDView.xaml" />
        </TabItem>
        <TabItem Header="Xaml">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="the Xaml-Code" />
                <TextBox
                    AllowDrop="False"
                    IsReadOnly="True"
                    Text="{x:Static p:Resources.ThreeDView}"
                    VerticalScrollBarVisibility="Visible" />
            </DockPanel>
        </TabItem>
        <TabItem Header="ViewModel">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="the ViewModel-Code" />
                <TextBox
                    AllowDrop="False"
                    IsReadOnly="True"
                    Text="{x:Static p:Resources.ThreeDViewModel}"
                    VerticalScrollBarVisibility="Visible" />
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
