<Window x:Class="TraceAnalysis.Show.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:widgets="clr-namespace:TraceAnalysis.Widgets.Wpf.Controls;assembly=TraceAnalysis.Widgets.Wpf"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="900"
        Width="1400"
        MinHeight="600"
        MinWidth="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Expander Margin="0,0,0,12"
                  Header="Open trace"
                  IsExpanded="False"
                  Visibility="{Binding IsOpenTraceAreaVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel Margin="8">
                <Button Padding="16,8"
                        Command="{Binding OpenTraceCommand}"
                        Content="Open Trace"
                        DockPanel.Dock="Left" />
                <TextBlock Margin="12,6,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding StatusText}" />
            </DockPanel>
        </Expander>

        <widgets:TraceChartControl Grid.Row="1"
                                   DataContext="{Binding TraceChart}" />

        <widgets:TraceCursorSummaryControl Grid.Row="2"
                                          Margin="0,12,0,0"
                                          DataContext="{Binding TraceChart}" />
    </Grid>
</Window>
