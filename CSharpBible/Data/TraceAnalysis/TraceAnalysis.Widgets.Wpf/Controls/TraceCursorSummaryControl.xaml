<UserControl x:Class="TraceAnalysis.Widgets.Wpf.Controls.TraceCursorSummaryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Cursor analysis">
        <StackPanel Margin="8">
            <StackPanel>
                <TextBlock FontWeight="Bold"
                           Text="{Binding CursorWindowText}" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding ViewWindowText}" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding ChartStatusText}" />
            </StackPanel>

            <Expander Margin="0,12,0,0"
                      Header="Nearest values"
                      IsExpanded="False">
                <DataGrid Margin="0,8,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          MaxHeight="240"
                          ItemsSource="{Binding CursorValues}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding CursorLabel}" Header="Cursor" Width="60" />
                        <DataGridTextColumn Binding="{Binding SeriesName}" Header="Series" Width="*" />
                        <DataGridTextColumn Binding="{Binding GroupName}" Header="Group" Width="120" />
                        <DataGridTextColumn Binding="{Binding TimeText}" Header="Time" Width="100" />
                        <DataGridTextColumn Binding="{Binding ValueText}" Header="Value" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Expander>

            <Expander Margin="0,12,0,0"
                      Header="Statistics between cursors"
                      IsExpanded="False">
                <DataGrid Margin="0,8,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          MaxHeight="240"
                          ItemsSource="{Binding CursorStatistics}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding SeriesName}" Header="Series" Width="*" />
                        <DataGridTextColumn Binding="{Binding SampleCountText}" Header="N" Width="60" />
                        <DataGridTextColumn Binding="{Binding MeanText}" Header="Mean" Width="90" />
                        <DataGridTextColumn Binding="{Binding MedianText}" Header="Median" Width="90" />
                        <DataGridTextColumn Binding="{Binding VarianceText}" Header="Variance" Width="90" />
                        <DataGridTextColumn Binding="{Binding IntegralText}" Header="Integral" Width="90" />
                        <DataGridTextColumn Binding="{Binding SlopeText}" Header="Slope" Width="90" />
                        <DataGridTextColumn Binding="{Binding MinimumText}" Header="Min" Width="90" />
                        <DataGridTextColumn Binding="{Binding MaximumText}" Header="Max" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Expander>
        </StackPanel>
    </GroupBox>
</UserControl>
