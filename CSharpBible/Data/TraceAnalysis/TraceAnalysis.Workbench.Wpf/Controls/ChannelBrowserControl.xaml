<UserControl x:Class="TraceAnalysis.Workbench.Wpf.Controls.ChannelBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Channels">
        <ListBox ItemsSource="{Binding Channels}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,2,0,2">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Name}" />
                        <TextBlock FontSize="11"
                                   Text="{Binding Group}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </GroupBox>
</UserControl>
