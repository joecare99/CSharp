<UserControl x:Class="TraceAnalysis.Workbench.Wpf.Controls.ProcessingEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Current Step">
        <DockPanel Margin="8">
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal">
                <Button Width="80"
                        Margin="0,0,8,0"
                        Command="{Binding NewCommand}"
                        Content="New" />
                <Button Width="80"
                        Margin="0,0,8,0"
                        Command="{Binding OpenCommand}"
                        Content="Open" />
                <Button Width="80"
                        Margin="0,0,8,0"
                        Command="{Binding SaveCommand}"
                        Content="Save" />
                <Button Width="90"
                        Command="{Binding SaveAsCommand}"
                        Content="Save As" />
                <TextBlock Margin="12,4,0,0"
                           Text="{Binding StatusText}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Margin="0,12,0,0">
                <TextBlock FontSize="16"
                           FontWeight="Bold"
                           Text="{Binding SelectedStepDetail.StepId}" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding SelectedStepDetail.OperationName}" />
            </StackPanel>

            <ScrollViewer Margin="0,12,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Expander Header="Inputs"
                              IsExpanded="True">
                        <ItemsControl Margin="12,8,12,12"
                                      ItemsSource="{Binding SelectedStepDetail.Inputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,6,8,0"
                                                   Text="Input Channel" />
                                        <ComboBox Grid.Column="1"
                                                  DisplayMemberPath="ChannelName"
                                                  ItemsSource="{Binding AvailableChannels}"
                                                  SelectedItem="{Binding SelectedChannel, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="Parameters"
                              Margin="0,8,0,0"
                              IsExpanded="True">
                        <ItemsControl Margin="12,8,12,12"
                                      ItemsSource="{Binding SelectedStepDetail.Parameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Margin="0,0,8,0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="Outputs"
                              Margin="0,8,0,0"
                              IsExpanded="True">
                        <ListBox Margin="12,8,12,12"
                                 ItemsSource="{Binding SelectedStepDetail.Outputs}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Margin="0,0,8,0"
                                                 FontWeight="SemiBold"
                                                 Text="{Binding OutputRole, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0,0,8,0"
                                                 Text="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding UnitText, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </GroupBox>
</UserControl>
