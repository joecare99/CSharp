<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
	<OutputType>Exe</OutputType>
	<TargetFramework>net8.0</TargetFramework>
	<ImplicitUsings>enable</ImplicitUsings>
	<Nullable>enable</Nullable>
	<AssemblyName>ProjectWithProjectReference</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
	<Compile Remove="ReferencedLibrary\**\*.cs" />
	<Compile Remove="ReferencedLibrary\obj\**\*.cs" />
	<Compile Remove="ReferencedLibrary\bin\**\*.cs" />
	<ProjectReference Include="ReferencedLibrary\ReferencedLibrary.csproj" />
  </ItemGroup>
</Project>
