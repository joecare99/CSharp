<Window x:Class="Document.Demo.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Document Export Demo"
        Height="520"
        Width="760"
        MinHeight="520"
        MinWidth="700">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Ausgabeformat:" />

        <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  Margin="0,0,8,8"
                  ItemsSource="{Binding OutputFormats}"
                  SelectedItem="{Binding SelectedOutputFormat}"
                  DisplayMemberPath="DisplayName"
                  MinWidth="240" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Dateiname:" />

        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,8,8"
                 Text="{Binding OutputFileName, UpdateSourceTrigger=PropertyChanged}" />

        <Button x:Name="btnChoosePath"
                Grid.Row="1"
                Grid.Column="2"
                Margin="0,0,0,8"
                Padding="14,4"
                Click="ChoosePath_Click"
                Content="Pfad wählen" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="Zielordner:" />

        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Grid.ColumnSpan="2"
                 Margin="0,0,0,12"
                 IsReadOnly="True"
                 Text="{Binding OutputDirectory}" />

        <GroupBox Grid.Row="3"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Header="Demo-Textbausteine"
                  Padding="10">
            <ItemsControl x:Name="lstFeatures"
                          ItemsSource="{Binding Features}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Margin="0,4,0,4"
                                  Content="{Binding DisplayName}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </GroupBox>

        <DockPanel Grid.Row="4"
                   Grid.Column="0"
                   Grid.ColumnSpan="3"
                   Margin="0,12,0,0">
            <TextBlock x:Name="lblStatus"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}" />
            <Button x:Name="btnExport"
                    DockPanel.Dock="Right"
                    Padding="18,6"
                    Command="{Binding ExportCommand}"
                    Content="Exportieren" />
        </DockPanel>
    </Grid>
</Window>
