<UserControl x:Class="RepoMigrator.App.Wpf.Views.SetupStageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Schritt 1: Quelle &amp; Ziel"
              Visibility="{Binding IsSetupStage, Converter={StaticResource BoolToVisibilityConverter}}">
        <StackPanel Margin="8">
            <TextBlock Text="{Binding SetupHintMessage}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Weiter"
                        Command="{Binding ContinueFromSetupCommand}"
                        IsEnabled="{Binding CanContinueFromSetup}"/>
            </StackPanel>
        </StackPanel>
    </GroupBox>
</UserControl>
