<Window x:Class="SharpHack.WPF2D.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharpHack.WPF2D.Converters"
        Title="SharpHack.WPF2D" Height="720" Width="1024"
        Focusable="True"
        Loaded="OnWindowLoaded"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Window.Resources>
        <conv:TileToImageConverter x:Key="TileToImageConverter" />
        <conv:TopEntityTileConverter x:Key="TopEntityTileConverter" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Player:" VerticalAlignment="Center"/>
            <TextBlock Text=" " />
            <TextBlock Text="{Binding Game.PlayerName}" VerticalAlignment="Center"/>

            <TextBlock Text="   HP:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <TextBlock Text="{Binding Game.HP}" VerticalAlignment="Center"/>
            <TextBlock Text="/" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Game.MaxHP}" VerticalAlignment="Center"/>

            <TextBlock Text="   Level:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <TextBlock Text="{Binding Game.Level}" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="Black">
            <ItemsControl x:Name="MapItemsControl"
                          ItemsSource="{Binding Game.Cells}"
                          MouseLeftButtonUp="OnMapMouseLeftButtonUp"
                          MouseMove="OnMapMouseMove"
                          MouseLeave="OnMapMouseLeave">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DataContext.Game.ViewWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#22000000" BorderThickness="0.5">
                            <Grid Width="96" Height="96">
                                <Image Width="96"
                                       Height="96"
                                       Stretch="Fill"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding Structure, Converter={StaticResource TileToImageConverter}}" />
                                <Image Width="96"
                                       Height="96"
                                       Stretch="Fill"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding Entities, Converter={StaticResource TopEntityTileConverter}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Expander Grid.Row="2" Margin="0,12,0,0" Header="Tile diagnostics" IsExpanded="True">
            <Border Padding="8" Background="#111" BorderBrush="#333" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding TilePalette}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Width="120" Margin="4">
                                <Border Width="96" Height="96" Background="Black" BorderBrush="#444" BorderThickness="1">
                                    <Image Width="96"
                                           Height="96"
                                           Stretch="Fill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Source="{Binding Tile, Converter={StaticResource TileToImageConverter}}" />
                                </Border>
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding Name}" />
                                <TextBlock Foreground="#AAA" Text="{Binding Index}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Expander>
    </Grid>
</Window>
