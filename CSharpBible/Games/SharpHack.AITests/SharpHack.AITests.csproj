<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="obj\**" />
	  <EmbeddedResource Remove="obj\**" />
	  <None Remove="obj\**" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.NET.Test.Sdk" />
		<PackageReference Include="MSTest" />
		<PackageReference Include="coverlet.collector">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SharpHack.AI\SharpHack.AI.csproj" />
		<ProjectReference Include="..\SharpHack.Base\SharpHack.Base.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <PackageVersion Update="coverlet.collector" Version="8.0.1" />
	  <PackageVersion Update="Microsoft.NET.Test.Sdk" Version="18.3.0" />
	  <PackageVersion Update="MSTest" Version="4.1.0" />
	</ItemGroup>

</Project>
