<Project>
  <Target Name="Any">
    <Message Text="$(TargetFramework) in the project file $(MSBuildProjectName)" />
  </Target>
  <Import Project="Packages.props" />
  <ItemGroup>
    <PackageVersion Include="IsExternalInit" Version="1.0.3" />
    <PackageVersion Include="MSTest" Version="4.1.0" />
    <PackageVersion Include="Microsoft.Build" Version="10.0.3" />
  </ItemGroup>
</Project>