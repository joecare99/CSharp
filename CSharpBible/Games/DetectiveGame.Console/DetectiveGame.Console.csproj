<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>false</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="obj\**" />
    <EmbeddedResource Remove="obj\**" />
    <None Remove="obj\**" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\BaseLib\BaseLib.csproj" />
    <ProjectReference Include="..\DetectiveGame.Engine\DetectiveGame.Engine.csproj" />
    <ProjectReference Include="..\..\Libraries\ExtendedConsole\ExtendedConsole.csproj" />
    <ProjectReference Include="..\..\Libraries\ConsoleLib\ConsoleLib.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Direkte Referenz erforderlich für Source-Generatoren von CommunityToolkit.Mvvm -->
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <PackageVersion Update="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageVersion Update="Microsoft.Extensions.DependencyInjection" Version="10.0.5" />
  </ItemGroup>
</Project>