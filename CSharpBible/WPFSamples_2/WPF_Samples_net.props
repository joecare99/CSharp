<Project>
  <PropertyGroup>
	  <AnalysisMode>All</AnalysisMode>
	  <UpDir>..\..</UpDir>
	  <BaseOutputPath>..\..\..\bin\$(MSBuildProjectName)\</BaseOutputPath>
    <BaseIntermediateOutputPath>..\..\..\obj.net\$(MSBuildProjectName)\</BaseIntermediateOutputPath>
	  <RootNamespace>$(MSBuildProjectName.Replace(".","_").Replace("_net",""))</RootNamespace>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <Company>JC-Soft</Company>
    <Authors>Joe Care</Authors>
    <Copyright>Copyright © JC-Soft 2026</Copyright>
    <Trademark>...</Trademark>
	  <UseArtifactsOutput>true</UseArtifactsOutput>
	  <SuppressTfmSupportBuildErrors>true</SuppressTfmSupportBuildErrors>
  </PropertyGroup>
</Project>