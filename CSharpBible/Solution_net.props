<Project>
	<PropertyGroup>
		<UpDir>..</UpDir>
		<AnalysisMode>All</AnalysisMode>
		<BaseOutputPath>$(UpDir)\..\bin\$(MSBuildProjectName)\</BaseOutputPath>
		<BaseIntermediateOutputPath>$(UpDir)\..\obj.net\$(MSBuildProjectName)\</BaseIntermediateOutputPath>
		<LangVersion>preview</LangVersion>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<Company>JC-Soft</Company>
		<Authors>Joe Care</Authors>
		<SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
		<SuppressTfmSupportBuildErrors>true</SuppressTfmSupportBuildErrors>
		<Copyright>Copyright © JC-Soft 2026</Copyright>
	</PropertyGroup>
</Project>