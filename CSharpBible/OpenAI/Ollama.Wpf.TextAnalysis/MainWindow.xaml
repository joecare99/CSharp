<Window x:Class="Ollama.Wpf.TextAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Content Analysis Sample"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnLoadFile"
                    Content="Load File"
                    Command="{Binding LoadFileCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="Auto"
                    Command="{Binding SelectAutoModeCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="Text"
                    Command="{Binding SelectTextModeCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="C#"
                    Command="{Binding SelectCSharpModeCommand}"
                    Padding="12,6"
                    Margin="0,0,12,0" />
            <Button x:Name="btnAnalyze"
                    Content="Analyze Content"
                    Command="{Binding AnalyzeTextCommand}"
                    Padding="12,6" />
            <TextBlock Margin="16,6,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText}" />
        </StackPanel>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Input" Margin="0,0,8,8">
            <TextBox x:Name="edtInput"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Summary" Margin="8,0,0,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Summary" FontWeight="Bold" />
                <TextBlock Grid.Row="1" Text="{Binding Summary}" TextWrapping="Wrap" Margin="0,4,0,8" />
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Mode: " FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedModeText}" Margin="0,0,16,0" />
                    <TextBlock Text="Score: " FontWeight="Bold" />
                    <TextBlock Text="{Binding ScoreText}" Margin="0,0,16,0" />
                    <TextBlock Text="Confidence: " FontWeight="Bold" />
                    <TextBlock Text="{Binding ConfidenceText}" />
                </StackPanel>
                <TextBox Grid.Row="3"
                         Text="{Binding RationaleText}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent" />
                <TextBlock Grid.Row="3"
                           Margin="0,8,0,0"
                           Text="{Binding RoutingReasonText}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Bottom" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Grid.Column="0" Header="Findings" Margin="0,8,8,0">
            <TextBox x:Name="edtFindings"
                     Text="{Binding FindingsText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
        </GroupBox>

        <GroupBox Grid.Row="3" Grid.Column="1" Header="Suggestions" Margin="8,8,0,0">
            <TextBox x:Name="edtSuggestions"
                     Text="{Binding SuggestionsText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
        </GroupBox>
    </Grid>
</Window>
