<Project>
  <Import Project="..\AA98_AvlnCodeStudio.props" />
  <PropertyGroup>
	<OutputType>WinExe</OutputType>
	<TargetFrameworks>net10.0</TargetFrameworks>
	<Nullable>enable</Nullable>
	<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
	<Configurations>Debug;Release;DesktopOnly</Configurations>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == 'DesktopOnly'">
	<DefineConstants>$(DefineConstants);AA98_ENABLE_DEBUG_DIAGNOSTICS</DefineConstants>
  </PropertyGroup>
  <Import Sdk="Microsoft.NET.Sdk" Project="Sdk.props" />
  <Import Sdk="Microsoft.NET.Sdk" Project="Sdk.targets" />
  <ItemGroup>
    <Compile Remove="Services\DevOpsPlanningProjectScaffolder.cs" />
    <Compile Remove="Services\DevOpsPlanningProjectScaffoldResult.cs" />
    <Compile Remove="Services\IDevOpsPlanningProjectScaffolder.cs" />
  </ItemGroup>

  <ItemGroup>
	<PackageReference Include="Avalonia" />
	<PackageReference Include="Avalonia.Desktop" />
	<PackageReference Include="Avalonia.Themes.Fluent" />
	<PackageReference Include="Avalonia.Fonts.Inter" />
	<PackageReference Include="AvaloniaUI.DiagnosticsSupport">
	  <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
	  <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
	  <PrivateAssets>all</PrivateAssets>
	  <IncludeAssets>none</IncludeAssets>
	</PackageReference>
	<PackageReference Include="CommunityToolkit.Mvvm" />
	<PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>

  <ItemGroup>
	<ProjectReference Include="..\AA98_AvlnCodeStudio.Diagnostics.Debug\AA98_AvlnCodeStudio.Diagnostics.Debug.csproj" />
	<ProjectReference Include="..\AA98_AvlnCodeStudio.Diagnostics.UI\AA98_AvlnCodeStudio.Diagnostics.UI.csproj" />
	<ProjectReference Include="..\AA98_AvlnCodeStudio.Planning.UI\AA98_AvlnCodeStudio.Planning.UI.csproj" />
  </ItemGroup>
</Project>
