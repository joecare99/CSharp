<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AA98_AvlnCodeStudio.UI.ViewModels"
        xmlns:controls="using:AA98_AvlnCodeStudio.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="AA98_AvlnCodeStudio.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Title="{Binding Editor.WindowTitle}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="New" Command="{Binding Editor.NewDocumentCommand}" />
            <Button Content="Open" Command="{Binding Editor.OpenCommand}" />
            <Button Content="Save" Command="{Binding Editor.SaveCommand}" />
            <Button Content="Save As" Command="{Binding Editor.SaveAsCommand}" />
            <TextBlock Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding Editor.CurrentFilePath}" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                Padding="8,6"
                BorderBrush="{DynamicResource ThemeControlMidBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock Text="{Binding Editor.StatusText}" />
        </Border>

        <controls:EditorTextArea MinHeight="300"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 Text="{Binding Editor.Text, Mode=TwoWay}" />
    </DockPanel>

</Window>
