<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			  xmlns:vm="using:FroniusMonitor.Core.ViewModels"
			 x:DataType="vm:FroniusDashboardViewModel"
			 x:Class="FroniusMonitor.Avalonia.Controls.PowerDistributionWidget">
  <Border Classes="dashboard-card">
	<StackPanel>
	  <TextBlock Classes="header" Text="Power distribution" />
	  <TextBlock Classes="secondary"
				 Margin="0,6,0,0"
				 Text="A graphical overview of how generation, storage, home consumption, and grid exchange relate right now." />

	  <Canvas x:Name="cnvDiagram" Width="860" Height="300" Margin="0,18,0,0" ClipToBounds="False">
		<Path x:Name="pthPvToHome" Data="M 84 106 Q 290 255 536 106" Stroke="{DynamicResource PvNodeBrush}" StrokeThickness="4" Opacity="0.55" IsVisible="{Binding ShowPvToHomePath}" />
		<Path x:Name="pthPvToBattery" Data="M 84 106 Q 200 180 306 106" Stroke="{DynamicResource PvNodeBrush}" StrokeThickness="3.5" Opacity="0.45" IsVisible="{Binding ShowPvToBatteryPath}" />
		<Path x:Name="pthBatteryToHome" Data="M 314 106 Q 418 188 536 106" Stroke="{DynamicResource BatteryNodeBrush}" StrokeThickness="3.5" Opacity="0.45" IsVisible="{Binding ShowBatteryToHomePath}" />
		<Path x:Name="pthBatteryToGrid" Data="M 314 106 Q 544 250 774 106" Stroke="{DynamicResource BatteryNodeBrush}" StrokeThickness="3.5" Opacity="0.4" IsVisible="{Binding ShowBatteryToGridPath}" />
		<Path x:Name="pthGridToHome" Data="M 774 106 Q 670 188 544 106" Stroke="{DynamicResource GridNodeBrush}" StrokeThickness="3.5" Opacity="0.5" IsVisible="{Binding ShowGridToHomePath}" />
		<Path x:Name="pthPvToGrid" Data="M 84 106 Q 432 286 774 106" Stroke="{DynamicResource PvNodeBrush}" StrokeThickness="4" Opacity="0.35" IsVisible="{Binding ShowPvToGridPath}" />

		<Border Canvas.Left="6" Canvas.Top="16" Width="156" Height="78" CornerRadius="18" Padding="14" Background="{DynamicResource PvNodeBackgroundBrush}" BorderBrush="{DynamicResource CardOutlineBrush}" BorderThickness="1">
		  <Grid ColumnDefinitions="Auto,*">
			<TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource PvNodeBrush}" Text="☀" />
			<StackPanel Grid.Column="1" Margin="14,0,0,0">
			  <TextBlock Classes="header" Text="PV" />
			  <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding PvPowerText}" />
			</StackPanel>
		  </Grid>
		</Border>

		<Border Canvas.Left="466" Canvas.Top="16" Width="156" Height="78" CornerRadius="18" Padding="14" Background="{DynamicResource HomeNodeBackgroundBrush}" BorderBrush="{DynamicResource CardOutlineBrush}" BorderThickness="1">
		  <Grid ColumnDefinitions="Auto,*">
			<TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource HomeNodeBrush}" Text="⌂" />
			<StackPanel Grid.Column="1" Margin="14,0,0,0">
			  <TextBlock Classes="header" Text="Home" />
			  <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding LoadPowerText}" />
			</StackPanel>
		  </Grid>
		</Border>

		<Border Canvas.Left="696" Canvas.Top="16" Width="156" Height="78" CornerRadius="18" Padding="14" Background="{DynamicResource GridNodeBackgroundBrush}" BorderBrush="{DynamicResource CardOutlineBrush}" BorderThickness="1">
		  <Grid ColumnDefinitions="Auto,*">
			<TextBlock FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource GridNodeBrush}" Text="▦" />
			<StackPanel Grid.Column="1" Margin="14,0,0,0">
			  <TextBlock Classes="header" Text="Grid" />
			  <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding GridPowerText}" />
			</StackPanel>
		  </Grid>
		</Border>

		<Canvas x:Name="cnvPacketLayer" Width="860" Height="300" IsHitTestVisible="False" />
	  </Canvas>
	</StackPanel>
  </Border>
</UserControl>
