<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			  xmlns:converters="using:FroniusMonitor.Avalonia.Converters"
			 x:Class="FroniusMonitor.Avalonia.App"
			 RequestedThemeVariant="Default">
	<Application.Resources>
	<converters:BooleanToIsVisibleConverter x:Key="BooleanToIsVisibleConverter" />
	<converters:AbsolutePowerToLogSizeConverter x:Key="AbsolutePowerToLogSizeConverter"
												MinimumSize="8"
												MaximumSize="24"
												ReferencePowerWatts="10000" />
	<converters:PercentageToWidthConverter x:Key="PercentageToWidthConverter"
										   MaximumWidth="56" />
	<converters:HalfValueToNegativeOffsetConverter x:Key="HalfValueToNegativeOffsetConverter" />
  </Application.Resources>
  <Application.Styles>
	<FluentTheme />
	  <StyleInclude Source="avares://FroniusMonitor.Avalonia/Styles/AppStyles.axaml" />
  </Application.Styles>
</Application>
