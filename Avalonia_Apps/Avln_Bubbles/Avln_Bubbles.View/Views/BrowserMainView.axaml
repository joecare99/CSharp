<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:Avln_Bubbles.View.ViewModels"
			 xmlns:views="using:Avln_Bubbles.View.Views"
			 x:Class="Avln_Bubbles.View.Views.BrowserMainView"
			 x:DataType="vm:MainWindowViewModel"
			 mc:Ignorable="d">
  <ScrollViewer>
	<StackPanel Margin="20" Spacing="20">
	  <Border Padding="18"
			  CornerRadius="18"
			  Background="#1AFFFFFF"
			  BorderBrush="#33FFFFFF"
			  BorderThickness="1">
		<views:ShellView DataContext="{Binding}" />
	  </Border>

	  <Border HorizontalAlignment="Center"
			  Padding="18"
			  CornerRadius="18"
			  Background="#14000000"
			  BorderBrush="#33FFFFFF"
			  BorderThickness="1">
		<views:BoardView Width="640" Height="640" DataContext="{Binding Board}" />
	  </Border>
	</StackPanel>
  </ScrollViewer>
</UserControl>
