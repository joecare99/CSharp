<Project>
  <Import Project="..\Avalonia_App01.props" />
  <PropertyGroup>
    <TargetFramework>net10.0-browser</TargetFramework>
    <OutputType>Exe</OutputType>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <Import Sdk="Microsoft.NET.Sdk.WebAssembly" Project="Sdk.props" />
  <Import Sdk="Microsoft.NET.Sdk.WebAssembly" Project="Sdk.targets" />
  <ItemGroup>
    <Compile Remove="obj\**" />
    <Content Remove="obj\**" />
    <EmbeddedResource Remove="obj\**" />
    <None Remove="obj\**" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia.Browser" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Avalonia_App_01\Avalonia_App_01.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="Tmds.DBus.Protocol">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <PackageVersion Update="Tmds.DBus.Protocol" Version="0.93.0" />
  </ItemGroup>
</Project>
