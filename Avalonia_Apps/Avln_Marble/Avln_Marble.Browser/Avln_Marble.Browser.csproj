<Project>
  <Import Project="..\Application.props" />
  <PropertyGroup>
	<TargetFramework>net10.0-browser</TargetFramework>
	<OutputType>Exe</OutputType>
	<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	<Nullable>enable</Nullable>
	<Configurations>Debug;Release;DesktopOnly</Configurations>
  </PropertyGroup>
  <Import Sdk="Microsoft.NET.Sdk.WebAssembly" Project="Sdk.props" />
  <Import Sdk="Microsoft.NET.Sdk.WebAssembly" Project="Sdk.targets" />
  <ItemGroup>
	<Compile Remove="obj\**" />
	<Content Remove="obj\**" />
	<EmbeddedResource Remove="obj\**" />
	<None Remove="obj\**" />
  </ItemGroup>
  <ItemGroup>
	<PackageReference Include="Avalonia.Browser" />
  </ItemGroup>
  <ItemGroup>
	<ProjectReference Include="..\Avln_Marble.Display\Avln_Marble.Display.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageVersion Update="Avalonia.Browser" Version="12.0.5" />
  </ItemGroup>
