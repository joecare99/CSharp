<UserControl
	x:Class="Avln_Marble.Display.Views.BrowserMainView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Avln_Marble.Display.ViewModels"
	xmlns:views="using:Avln_Marble.Display.Views"
	x:DataType="vm:MainWindowViewModel"
	Focusable="True"
	KeyDown="BrowserMainView_OnKeyDown"
	mc:Ignorable="d">
  <Grid Margin="24">
	<Grid.RowDefinitions>
	  <RowDefinition Height="Auto" />
	  <RowDefinition Height="24" />
	  <RowDefinition Height="*" />
	  <RowDefinition Height="24" />
	  <RowDefinition Height="Auto" />
	</Grid.RowDefinitions>

	<TextBlock FontSize="30"
			   FontWeight="SemiBold"
			   Foreground="#FFF8F0DB"
			   TextWrapping="Wrap"
			   Text="Marble Board Prototype" />

	<views:BoardView Grid.Row="2" HorizontalAlignment="Left" DataContext="{Binding Board}" />

	<Border Grid.Row="4"
			Padding="18"
			CornerRadius="18"
			Background="#1AFFFFFF"
			BorderBrush="#2E7AC8FF"
			BorderThickness="1">
	  <StackPanel Spacing="12">
		<TextBlock FontSize="19"
				   FontWeight="SemiBold"
				   Foreground="#FFF8F0DB"
				   Text="Board status" />
		<TextBlock TextWrapping="Wrap"
				   Foreground="#FFD5D9E0"
				   Text="{Binding Board.StatusText}" />
	  </StackPanel>
	</Border>
  </Grid>
</UserControl>
