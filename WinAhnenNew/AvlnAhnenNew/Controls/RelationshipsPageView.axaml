	<Label x:Name="Label61" Canvas.Left="192" Canvas.Top="543" Content="Quelle" />
	<Label x:Name="Label65" Canvas.Left="69" Canvas.Top="600" Content="Scheidung (Trennung)" />
	<Label x:Name="Label66" Canvas.Left="197" Canvas.Top="635" Content="Quelle" />
	<Label x:Name="Label67" Canvas.Left="59" Canvas.Top="17" Width="1" Height="1" Background="#C0C0C0" Content="" />
	<Label x:Name="Label69" Canvas.Left="268" Canvas.Top="333" Content="Label22" />
	<Label x:Name="Label71" Canvas.Left="269" Canvas.Top="600" Content="Label22" />
	<Label x:Name="Label70" Canvas.Left="268" Canvas.Top="468" Content="Label22" />
	<DataGrid x:Name="StringGrid3" Canvas.Left="55" Canvas.Top="60" Width="531" Height="235" />
