	<TextBox x:Name="DBEdit41" Canvas.Left="339" Canvas.Top="464" Width="32" />
	<TextBox x:Name="DBEdit45" Canvas.Left="376" Canvas.Top="464" Width="61" />
	<TextBox x:Name="DBEdit46" Canvas.Left="301" Canvas.Top="504" Width="679" />
	<ComboBox x:Name="DBComboBox1" Canvas.Left="711" Canvas.Top="57" Width="241" IsEditable="True" />
	<TextBox x:Name="DBEdit61" Canvas.Left="301" Canvas.Top="596" Width="32" />
