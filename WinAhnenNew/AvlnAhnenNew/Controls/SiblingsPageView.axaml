<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:controls="using:AvlnAhnenNew.Controls"
			  x:Class="AvlnAhnenNew.Controls.SiblingsPageView"
			 x:CompileBindings="False">
	<Grid Margin="12">
	<Grid.RowDefinitions>
	  <RowDefinition Height="Auto" />
	  <RowDefinition Height="12" />
	  <RowDefinition Height="*" />
	</Grid.RowDefinitions>
	<controls:PersonHeaderView />
	<Canvas Grid.Row="2">
	  <Label x:Name="Label26" Width="1" Height="1" Background="#C0C0C0" Canvas.Left="267" Canvas.Top="36" Content="" />
	  <DataGrid x:Name="StringGrid4" Width="531" Height="408" Canvas.Left="260" Canvas.Top="105" />
	</Canvas>
  </Grid>
</UserControl>
