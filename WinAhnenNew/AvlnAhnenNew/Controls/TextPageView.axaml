<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:controls="using:AvlnAhnenNew.Controls"
			  x:Class="AvlnAhnenNew.Controls.TextPageView"
			 x:CompileBindings="False">
	<Grid Margin="12">
	<Grid.RowDefinitions>
	  <RowDefinition Height="Auto" />
	  <RowDefinition Height="12" />
	  <RowDefinition Height="*" />
	</Grid.RowDefinitions>
	<controls:PersonHeaderView />
	<Canvas Grid.Row="2">
	  <Label x:Name="Label21" Width="1" Height="1" Canvas.Left="64" Canvas.Top="15" Content="" />
	  <TextBox x:Name="DBMemo1"
			 Width="823"
			 Height="577"
			 AcceptsReturn="True"
			 TextWrapping="Wrap"
			  ScrollViewer.VerticalScrollBarVisibility="Auto"
			 Canvas.Left="64"
			 Canvas.Top="53" />
	</Canvas>
  </Grid>
</UserControl>
