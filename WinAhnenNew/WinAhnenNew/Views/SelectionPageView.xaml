<Page x:Class="WinAhnenNew.Views.SelectionPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WinAhnenNew.Views"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1050"
      Title="SelectionPageView">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            Background="#F8F8F8"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,8,8"
                    VerticalAlignment="Center"
                    Text="Filter" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="3"
                    Margin="0,0,8,8"
                    VerticalAlignment="Center"
                    Text="Sortierung" />
                <ComboBox
                    Grid.Row="0"
                    Grid.Column="4"
                    Margin="0,0,0,8"
                    ItemsSource="{Binding SortFields}"
                    SelectedItem="{Binding SelectedSortField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox
                    Grid.Row="0"
                    Grid.Column="6"
                    Margin="0,0,16,8"
                    VerticalAlignment="Center"
                    Content="Absteigend"
                    IsChecked="{Binding SortDescending, Mode=TwoWay}" />

                <Button
                    Grid.Row="0"
                    Grid.Column="7"
                    Margin="0,0,8,8"
                    Command="{Binding ResetFilterCommand}"
                    Content="Zurücksetzen"
                    Padding="12,4" />

                <CheckBox
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="Nur lebende Personen"
                    IsChecked="{Binding OnlyLiving, Mode=TwoWay}" />

                <Button
                    Grid.Row="1"
                    Grid.Column="7"
                    Command="{Binding SelectPersonCommand}"
                    Content="Person übernehmen"
                    Padding="12,4" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding SelectionStatusText}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Text="{Binding FilteredPersonCount, StringFormat=Treffer: {0}}" />
        </Grid>

        <DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            IsReadOnly="True"
            ItemsSource="{Binding PersonsView}"
            SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding ID}" Header="Nr." Width="80" />
                <DataGridTextColumn Binding="{Binding Surname}" Header="Nachname" Width="*" />
                <DataGridTextColumn Binding="{Binding GivenName}" Header="Vorname" Width="*" />
                <DataGridTextColumn Binding="{Binding Sex}" Header="Geschlecht" Width="110" />
                <DataGridTextColumn Binding="{Binding BirthDate.DateText}" Header="Geburtsdatum" Width="140" />
                <DataGridTextColumn Binding="{Binding BirthPlace.Name}" Header="Geburtsort" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="3"
            Margin="0,12,0,0"
            Padding="16"
            Background="#F8F8F8"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Text="ID" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" Text="{Binding SelectedPersonId, Mode=OneWay}" />
                <TextBlock Grid.Row="0" Grid.Column="3" Margin="0,0,8,8" Text="Name" />
                <TextBox Grid.Row="0" Grid.Column="4" Margin="0,0,0,8" IsReadOnly="True" Text="{Binding SelectedPersonName, Mode=OneWay}" />
                <TextBlock Grid.Row="0" Grid.Column="6" Margin="0,0,8,8" Text="Geschlecht" />
                <TextBox Grid.Row="0" Grid.Column="7" Margin="0,0,0,8" IsReadOnly="True" Text="{Binding SelectedPersonSex, Mode=OneWay}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Text="Geburtsdatum" />
                <TextBox Grid.Row="1" Grid.Column="1" IsReadOnly="True" Text="{Binding SelectedPersonBirthDate, Mode=OneWay}" />
                <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,0,8,0" Text="Geburtsort" />
                <TextBox Grid.Row="1" Grid.Column="4" IsReadOnly="True" Text="{Binding SelectedPersonBirthPlace, Mode=OneWay}" />
                <CheckBox Grid.Row="1" Grid.Column="7" Content="Person ausgewählt" IsChecked="{Binding IsPersonSelected, Mode=OneWay}" IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Page>
