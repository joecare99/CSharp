<UserControl x:Class="WinAhnenNew.Controls.PersonHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="180"
             d:DesignWidth="900"
             mc:Ignorable="d">
    <Border
        Padding="12"
        Background="#F8F8F8"
        BorderBrush="#D0D0D0"
        BorderThickness="1"
        CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="Person" />
                <TextBox
                    Grid.Column="1"
                    IsReadOnly="True"
                    Text="{Binding DisplayName, Mode=OneWay}" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="12" BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="4">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Content="Vater" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" MinWidth="240" IsReadOnly="True" Text="{Binding Father, Mode=OneWay}" />
                        <Label Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Content="Mutter" />
                        <TextBox Grid.Row="1" Grid.Column="1" MinWidth="240" IsReadOnly="True" Text="{Binding Mother, Mode=OneWay}" />
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Content="Nr." />
                    <Border Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" MinHeight="27" Padding="4" BorderBrush="#B0B0B0" BorderThickness="1">
                        <TextBlock Padding="2" VerticalAlignment="Center" Text="{Binding PersonNumber, Mode=OneWay}" />
                    </Border>
                    <ToggleButton Grid.Row="0" Grid.Column="2" Width="31" Height="27" Margin="8,0,0,8" HorizontalAlignment="Right" IsChecked="{Binding IsSelectPersonToggled, Mode=OneWay}" IsEnabled="False" />
                    <Label Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Content="ID" />
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" IsReadOnly="True" Text="{Binding Id, Mode=OneWay}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Zusatz" />
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" IsReadOnly="True" Text="{Binding AdditionalInfo, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
